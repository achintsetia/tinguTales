rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Client uploads child photo — only the owning user, images only, max 10 MB
    match /{userId}/uploads/{filename} {
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.contentType.matches('image/.*')
        && request.resource.size <= 10 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Avatar files are written by Cloud Functions (Admin SDK bypasses rules).
    // Only the owning user can read them.
    match /{userId}/{profileId}/avatar/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
