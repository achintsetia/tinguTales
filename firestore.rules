rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can read and write only their own profile
    match /user_profile/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Child profiles — users can only access their own
    match /child_profiles/{profileId} {
      allow read, update, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
    }

    // Model configs — any authenticated user can read, only admins can write
    match /models/{modelId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/user_profile/$(request.auth.uid)).data.is_admin == true;
    }

    // Transliteration cache — any authenticated user can read; writes via Cloud Functions only
    match /name_transliteration/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Stories — users can read/delete their own; partial client updates allowed for wizard fields
    match /stories/{storyId} {
      allow read, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
      // Allow the owner to update only safe wizard metadata fields (no status or draft_pages tampering)
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'draft_pages', 'user_id', 'profile_id', 'created_at']);
      allow create, write: if false;

      // Pages subcollection — owner can read (for real-time generation progress); writes via Cloud Functions only
      match /pages/{pageId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/stories/$(storyId)).data.user_id == request.auth.uid;
        allow write: if false;
      }
    }

    // All other collections are locked down by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
